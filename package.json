{
  "name": "card-deck-crafter-v2-monorepo",
  "private": true,
  "version": "2.0.0",
  "description": "Monorepo para Card Deck Crafter v2",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run client:dev",
    "client:dev": "npm run dev -w client",
    "client:build": "npm run build -w client",
    "server:dev": "npm run dev -w server",
    "server:start": "npm run start -w server",
    "test": "vitest run"
  }
}
